# ttyd settings
USE_TTYD=true # Set this to true to enable a read-only web interface showing the output from viewadsb, served on the port specified with TTYD_PORT.
TTYD_PORT=1234 # Some SDR programs like to use this port for their own services, so many users may find it helpful to use a different port number here.
BEAST_CONNECTIONS=(127.0.0.1,30005,beast_in) # Sources to gather ADS-B data from. Multiple entries will aggregate data into one place.

# readsb settings
USE_READSB=true # Set this to true in order to use readsb to obtain data from a tuning device and provide it over the network.
DEVICE_TYPE=rtlsdr # The type of device that readsb should search for.
BEAST_PORT_OUT=30005 # Network port to send Beast data over. This should be 30005 unless using that port would break something else.
BEAST_BIND_ADDR=0.0.0.0 # Set this to 127.0.0.1 to prevent external Beast connections.